{
  "tasks": {
    "dev": "deno run --watch main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "permissions": {
    "default": {
      "read": true,
      "net": true,
      "env": true,
      "sys": true
    }
  },
  "imports": {
    "@storage": "../common/s3-client.ts",
    "@queue-message": "../common/sqs-client.ts",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.994.0",
    "@aws-sdk/client-sqs": "npm:@aws-sdk/client-sqs@^3.1004.0",
    "@std/assert": "jsr:@std/assert@1",
    "hono": "jsr:@hono/hono@^4.11.10",
    "@aws-sdk/s3-request-presigner": "npm:@aws-sdk/s3-request-presigner@^3.995.0"
  }
}
